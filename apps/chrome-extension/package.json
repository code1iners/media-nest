{
  "name": "chrome-extension",
  "version": "1.0.0",
  "private": true,
  "description": "Media Nest WXT Chrome extension.",
  "scripts": {
    "build": "wxt build && node tools/verify-extension-package.js",
    "dev": "node tools/run-wxt-dev-ready.js",
    "lint": "wxt prepare && tsc --noEmit",
    "postinstall": "wxt prepare",
    "test": "vitest run",
    "test:browser": "wxt build && node tools/verify-extension-package.js && node tests/browser/popup-smoke.mjs",
    "test:browser:dev": "MEDIA_NEST_POPUP_SMOKE_MODE=dev node tests/browser/popup-smoke.mjs",
    "zip": "wxt zip"
  },
  "dependencies": {
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.43",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "1.2.2",
    "playwright": "1.61.0",
    "typescript": "5.9.3",
    "vitest": "4.1.9",
    "wxt": "0.20.26"
  }
}
