{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "description": "MyTube Extract NestJS API server.",
  "license": "UNLICENSED",
  "author": "",
  "main": "dist/main.js",
  "files": [
    "dist",
    "scripts",
    "package.json"
  ],
  "scripts": {
    "build": "nest build",
    "dev": "NODE_ENV=development nest start --watch",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,test}/**/*.ts\" --fix",
    "start": "NODE_ENV=production nest start",
    "start:debug": "nest start --debug --watch",
    "start:dev": "NODE_ENV=development nest start --watch",
    "start:prod": "NODE_ENV=production node dist/main",
    "test": "jest",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register ../../node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:watch": "jest --watch",
    "verify:runtime": "sh scripts/verify-runtime-dependencies.sh"
  },
  "jest": {
    "collectCoverageFrom": [
      "src/**/*.(t|j)s"
    ],
    "coverageDirectory": "coverage",
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "moduleNameMapper": {
      "^@mytube-extract/db$": "<rootDir>/../../packages/db/src/index.ts"
    },
    "rootDir": ".",
    "testEnvironment": "node",
    "testRegex": "src/.*\\.spec\\.ts$",
    "transform": {
      "^.+\\.ts$": "ts-jest"
    }
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1079.0",
    "@aws-sdk/s3-request-presigner": "^3.1079.0",
    "@ce1pers/random-helpers": "^1.1.3",
    "@mytube-extract/db": "workspace:*",
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/schedule": "^6.1.3",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "youtube-dl-exec": "3.1.8",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.27",
    "@types/express": "^4.17.17",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.21",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^30.4.2",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  }
}
