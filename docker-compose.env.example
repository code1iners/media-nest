NODE_ENV=production
PORT=3030

DATABASE_URL=
DIRECT_URL=

R2_ENDPOINT=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BASE_URL=

ASSET_RETENTION_DAYS=7
WORKER_HEARTBEAT_STALE_MS=15000
WORKER_LOOP_INTERVAL_MS=5000
WORKER_PROCESSING_TIMEOUT_MS=3600000
SUBTITLE_UPLOAD_MAX_BYTES=1073741824
SUBTITLE_AUDIO_MAX_BYTES=536870912
